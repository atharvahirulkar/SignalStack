# signalstack - environment variables
# Copy to .env and fill in your values.
# Never commit .env to git.

# ── Polygon.io ────────────────────────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here

# Comma-separated tickers, or * for all trades
TICKERS=AAPL,TSLA,MSFT,NVDA,AMZN,GOOGL,META,SPY,QQQ

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092   # overridden to kafka:29092 inside Docker
KAFKA_TOPIC=market.trades
KAFKA_LINGER_MS=5
KAFKA_BATCH_SIZE=65536
KAFKA_COMPRESSION=lz4

# ── TimescaleDB ───────────────────────────────────────────────────────────────
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=signalstack

# Internal Docker connection (container-to-container - always port 5432)
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432

# Full DSN used by app services (inside Docker, port 5432)
# From your host machine use port 5433 (docker-compose maps 5433→5432)
TIMESCALE_DSN=postgresql://your_db_user:your_db_password@timescaledb:5432/signalstack

# ── Writer ────────────────────────────────────────────────────────────────────
WRITER_BATCH_SIZE=500
WRITER_FLUSH_INTERVAL=0.5
WRITER_MAX_QUEUE=50000

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_MASTER=local[*]
CHECKPOINT_DIR=/tmp/signalstack-checkpoints

# ── Backfill ──────────────────────────────────────────────────────────────────
BACKFILL_REQUEST_DELAY=0.25
BACKFILL_LOOKBACK_DAYS=3
BACKFILL_SCHEDULE_HOUR=6
BACKFILL_SYMBOLS=AAPL,TSLA,MSFT,NVDA,AMZN,GOOGL,META,SPY,QQQ

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
